# =========================================================
# TELEOPS-AI CONFIG
# =========================================================

# ---------------------------------------------------------
# GENERAL
# ---------------------------------------------------------
APP_NAME=TeleOps-AI
APP_ENV=development
DEBUG=true
TIMEZONE=Asia/Bangkok
LOG_LEVEL=INFO

# ---------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Admin IDs (comma separated)
TELEGRAM_ADMIN_IDS=123456789,987654321

# Allowed chat types
ALLOW_PRIVATE_CHATS=true
ALLOW_GROUP_CHATS=true

# ---------------------------------------------------------
# SECURITY
# ---------------------------------------------------------

# Secret keys
SECRET_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME_TOO

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Encryption
FERNET_KEY=

# Default deny policy
DEFAULT_DENY=true

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30

# Session
SESSION_TIMEOUT_MINUTES=60

# ---------------------------------------------------------
# DATABASE
# ---------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/teleops.db

# ---------------------------------------------------------
# AI PROVIDER
# ---------------------------------------------------------

# Provider options:
# openai
# groq
# openrouter
AI_PROVIDER=groq

# System prompt behavior
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# ---------------------------------------------------------
# OPENAI
# ---------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------
# GROQ
# ---------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ---------------------------------------------------------
# OPENROUTER
# ---------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------
# INTERNET / WEB SEARCH
# ---------------------------------------------------------
ENABLE_INTERNET_ACCESS=true
ENABLE_WEB_SEARCH=true

SEARCH_TIMEOUT_SECONDS=20
MAX_SEARCH_RESULTS=5

# ---------------------------------------------------------
# CALENDAR / REMINDERS
# ---------------------------------------------------------
ENABLE_REMINDERS=true

# Reminder schedule
REMINDER_BEFORE_HOURS=12
REMINDER_BEFORE_MINUTES=60

# ---------------------------------------------------------
# RBAC / PERMISSIONS
# ---------------------------------------------------------
ENABLE_RBAC=true

# Roles
DEFAULT_USER_ROLE=user
ADMIN_ROLE_NAME=admin

# ---------------------------------------------------------
# INBOX SYSTEM
# ---------------------------------------------------------
ENABLE_SHARED_INBOX=true
ENABLE_PRIVATE_INBOX=true

# Sensitive commands private-only
PRIVATE_ONLY_COMMANDS=/admin,/grant,/revoke,/config

# ---------------------------------------------------------
# AUDIT LOGGING
# ---------------------------------------------------------
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=90

# ---------------------------------------------------------
# FEATURE TOGGLES
# ---------------------------------------------------------
ENABLE_AI_CHAT=true
ENABLE_PLUGINS=true
ENABLE_FILE_UPLOADS=true
ENABLE_RCLONE=false

# ---------------------------------------------------------
# RCLONE
# ---------------------------------------------------------
RCLONE_CONFIG_PATH=
RCLONE_REMOTE_NAME=

# ---------------------------------------------------------
# CACHE
# ---------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# ---------------------------------------------------------
# FILE STORAGE
# ---------------------------------------------------------
UPLOAD_DIR=./data/uploads
CACHE_DIR=./data/cache
LOG_DIR=./data/logs
BACKUP_DIR=./data/backups

# ---------------------------------------------------------
# APSCHEDULER
# ---------------------------------------------------------
SCHEDULER_TIMEZONE=Asia/Bangkok

# ---------------------------------------------------------
# DEVELOPMENT
# ---------------------------------------------------------
DEV_MODE=true
MOCK_AI_RESPONSES=false
